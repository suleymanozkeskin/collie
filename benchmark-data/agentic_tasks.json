      "prompt": "find where the hollow kubelet actually runs",
      "expected_paths": ["pkg/kubemark/hollow_kubelet.go"],
      "collie_symbol_queries": [
        "kind:method path:pkg/kubemark/ qname:HollowKubelet::Run",
        "kind:method path:pkg/kubemark/ %run%"
