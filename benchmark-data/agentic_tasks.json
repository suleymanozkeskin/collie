{
  "version": 1,
  "tasks": [
    {
      "id": "collie.resolve-worktree-root",
      "repo": "collie-search",
      "prompt": "find the function that resolves the worktree root before daemon operations",
      "expected_paths": ["src/daemon/mod.rs"],
      "collie_symbol_queries": [
        "kind:fn path:src/daemon/ %worktree%",
        "kind:fn path:src/daemon/ %resolve%"
      ],
      "collie_lexical_queries": [
        "worktree",
        "resolve_worktree_root"
      ],
      "rg_regex_queries": [
        "worktree",
        "resolve_.*worktree"
      ]
    },
    {
      "id": "collie.extract-snippets",
      "repo": "collie-search",
      "prompt": "find the snippet extraction logic used by CLI search output",
      "expected_paths": ["src/cli/search.rs"],
      "collie_symbol_queries": [
        "kind:fn path:src/cli/ %snippet%",
        "kind:fn path:src/cli/ %extract%"
      ],
      "collie_lexical_queries": [
        "snippet",
        "extract_snippets"
      ],
      "rg_regex_queries": [
        "snippet",
        "extract_.*snippet"
      ]
    },
    {
