#!/bin/sh

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

needs_sync=0

if ! git diff --quiet -- .agents/skills/SKILL.md scripts/sync_plugin_skill.py plugins/collie/skills/use-collie/SKILL.md; then
    needs_sync=1
fi

if ! git diff --cached --quiet -- .agents/skills/SKILL.md scripts/sync_plugin_skill.py plugins/collie/skills/use-collie/SKILL.md; then
    needs_sync=1
fi

if [ "$needs_sync" -eq 0 ]; then
    exit 0
fi

python3 scripts/sync_plugin_skill.py
git add plugins/collie/skills/use-collie/SKILL.md

